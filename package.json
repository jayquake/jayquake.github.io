{
  "name": "accessibility-rule-testing",
  "version": "0.1.0",
  "homepage": "https://jayquake.github.io/",
  "private": true,
  "proxy": "http://localhost:3001",
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@mui/utils": "^7.3.8",
    "@mui/x-tree-view": "^8.27.2",
    "@playwright/mcp": "^0.0.46",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "accessflow-mcp-server": "^1.0.15",
    "ansi-to-html": "^0.7.2",
    "dompurify": "^3.2.3",
    "framer-motion": "^11.15.0",
    "prismjs": "^1.30.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-code-blocks": "^0.1.6",
    "react-code-section-lib": "^0.1.2",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.14.1",
    "react-scripts": "^5.0.1",
    "socket.io-client": "^4.6.1",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@acsbe/accessflow-sdk": "file:nodeSDK/acsbe-accessflow-sdk-1.1.1.tgz",
    "@playwright/test": "^1.56.1",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.1.2",
    "customize-cra": "^1.0.0",
    "dotenv": "^17.2.3",
    "gh-pages": "^6.2.0",
    "playwright": "^1.56.1",
    "react-app-rewired": "^2.2.1",
    "selenium-webdriver": "^4.32.0",
    "node-fetch": "^2.7.0",
    "typescript": "^5.4.5"
  },
  "scripts": {
    "start": "PORT=3003 react-app-rewired start",
    "predeploy": "npm run build",
    "deploy": "bash scripts/deploy-via-actions.sh",
    "deploy:direct": "gh-pages -d build",
    "deploy:actions": "bash scripts/deploy-via-actions.sh",
    "deploy:trigger": "gh workflow run deploy.yml",
    "prebuild": "node scripts/generate-static-projects.js",
    "build": "npm run prebuild && CI=false react-app-rewired build",
    "test": "react-app-rewired test",
    "eject": "react-scripts eject",
    "test:e2e": "cd selenium-test-suite && npx jest --config jest.config.js",
    "test:e2e:headed": "cd selenium-test-suite && HEADLESS=false npx jest --config jest.config.js",
    "test:e2e:sdk": "cd selenium-test-suite && npx jest --config jest.config.js tests/sdk-audit-init-and-basic-reports.test.js",
    "test:e2e:search": "cd selenium-test-suite && npx jest --config jest.config.js tests/sdk-audit-search-component.test.js",
    "test:e2e:graphics": "cd selenium-test-suite && npx jest --config jest.config.js tests/sdk-audit-graphics-multi-state.test.js",
    "test:e2e:breadcrumb": "cd selenium-test-suite && npx jest --config jest.config.js tests/sdk-audit-breadcrumb-navigation.test.js",
    "test:e2e:timing": "cd selenium-test-suite && npx jest --config jest.config.js tests/sdk-audit-navigation-timing.test.js",
    "test:e2e:hidden": "cd selenium-test-suite && npx jest --config jest.config.js tests/sdk-audit-hidden-content-thresholds.test.js",
    "test:e2e:playwright": "cd test-suite && npx playwright test",
    "test:e2e:playwright:run": "cd test-suite && playwright test",
    "test:e2e:playwright:ui": "cd test-suite && playwright test --ui",
    "test:e2e:playwright:report": "cd test-suite && playwright show-report",
    "setup": "npm install --legacy-peer-deps && cd server && npm install && npx prisma generate && npx prisma db push",
    "server:dev": "cd server && npm run dev",
    "server:install": "cd server && npm install",
    "server:db:push": "cd server && npx prisma db push",
    "server:db:studio": "cd server && npx prisma studio",
    "dev:full": "concurrently -n frontend,backend -c cyan,green \"npm start\" \"npm run server:dev\"",
    "mcp:start": "npx @playwright/mcp --port 3002",
    "dev:all": "npm run dev:full"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "peerDependencies": {
    "yaml": "^2.8.1"
  }
}
