{
  "name": "audit-rules-server",
  "version": "1.0.0",
  "description": "Backend server for audit-rules test runner and MCP analysis",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:studio": "npx prisma studio",
    "prisma:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:clear": "tsx src/scripts/clearDatabase.ts",
    "db:stats": "tsx -e \"import('./src/infrastructure/database/DatabaseService').then(m => m.DatabaseService.getInstance().getStats().then(s => console.log(JSON.stringify(s, null, 2))))\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@playwright/test": "^1.44.0",
    "@prisma/client": "^6.19.1",
    "axios": "^1.6.0",
    "bottleneck": "^2.19.5",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "http-proxy-middleware": "^2.0.9",
    "p-limit": "^3.1.0",
    "prisma": "^6.19.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.1",
    "typescript": "^5.4.5"
  }
}
